# Application
NODE_ENV=development
PORT=3000
APP_NAME=Vehicle Inspection API
APP_VERSION=1.0.0

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=vehicle_inspection_dev
DB_SYNCHRONIZE=false
DB_LOGGING=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRATION=86400

# AWS S3 (for photos/videos storage)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=vehicle-inspection-bucket

# Firebase (for notifications)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Vision AI APIs
GOOGLE_VISION_API_KEY=
AWS_REKOGNITION_ENABLED=true

# OBD Integration
OBD_ENABLE_BLUETOOTH=true
OBD_ADAPTER_TYPE=ELM327

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# CORS
CORS_ORIGIN=http://localhost:3001,http://localhost:8081

# Blockchain (optional)
BLOCKCHAIN_ENABLED=false
ETHEREUM_RPC_URL=
ETHEREUM_PRIVATE_KEY=
SMART_CONTRACT_ADDRESS=
